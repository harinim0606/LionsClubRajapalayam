# Lions Club Member Management Portal Environment Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB Atlas)
# Place your MongoDB Atlas URI here (will be provided by the user)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lions_club?retryWrites=true&w=majority

# Authentication Secret
# Generate a secure random string for JWT signing
JWT_SECRET=your_super_secret_jwt_key_here
